{
  "title": "Application Health Dashboard",
  "timezone": "browser",
  "panels": [
    {
      "title": "Requests Per Second",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])"
        }
      ]
    },
    {
      "title": "API Errors",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(api_errors_total[5m])"
        }
      ]
    },
    {
      "title": "Latency P95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(request_latency_seconds_bucket[5m]))"
        }
      ]
    },
    {
      "title": "Latency P99",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(request_latency_seconds_bucket[5m]))"
        }
      ]
    }
  ]
}